{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],

    // ✅ This fixes the non-relative path error
    "baseUrl": "./src",

    // ✅ Correct paths relative to baseUrl
    "paths": {
      "@/*": ["*"],
      "@generated": ["generated/client"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "src/components/PageComponents/GallaryPage/GallaryAlbum.jsx"
  ],
  "exclude": ["node_modules"]
}